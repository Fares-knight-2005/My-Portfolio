---
import personal from '../data/personal.json';
---

<section id="about" class="py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-3xl font-bold mb-8 text-center" data-aos="fade-up">About Me</h2>
    <div class="flex flex-col md:flex-row items-center gap-10" data-aos="fade-up">
      <p class="text-gray-400 leading-relaxed text-lg flex-1">
        {personal.bio}
        <br/><br/>
        I Particepated in many ICPC Contests Got First Place On University Level Once.
      </p>
      <img
        src={personal.avatar}
        alt={personal.name}
        class="w-64 h-64 rounded-2xl object-cover shadow-xl"
      />
    </div>
  </div>
</section>