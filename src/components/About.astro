---
import personal from '../data/personal.json';
import { getAssetPath } from '../utils/path.js';
---

<section id="about" class="py-20">
  <div class="container mx-auto px-6 max-w-4xl">
    <h2 class="text-3xl font-bold mb-8 text-center" data-aos="fade-up">About Me</h2>
    <div class="flex flex-col md:flex-row items-center gap-10" data-aos="fade-up">
      <p class="text-gray-400 leading-relaxed text-lg flex-1">
        {personal.bio}
        <br/><br/>
        I believe clean, maintainable code is the foundation of any successful system. Outside of the screen, I enjoy contributing to open-source projects and sharing knowledge.
      </p>
      <img
        src={getAssetPath(personal.avatar)}
        alt={personal.name}
        class="w-80 h-80 md:w-96 md:h-96 rounded-2xl object-cover shadow-xl"
      />
    </div>
  </div>
</section>