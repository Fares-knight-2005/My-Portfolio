---
import skills from '../data/skills.json';

// SVG icons as plain HTML strings (no JSX)
const skillIcons = {
  '.Net Core': `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`,
  '.Net Framework Windows Forms': `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>`,
  'SQL Server': `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>`,
  'Git': `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"></circle><circle cx="19" cy="6" r="2"></circle><circle cx="12" cy="18" r="2"></circle><path d="M5 8v2a4 4 0 0 0 4 4h6a4 4 0 0 0 4-4V8"></path><line x1="7" y1="8" x2="11" y2="14"></line><line x1="17" y1="8" x2="13" y2="14"></line></svg>`,
  'ADO.NET': `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path><circle cx="18" cy="16" r="1.5" fill="currentColor" stroke="none"></circle><circle cx="15" cy="14" r="1.5" fill="currentColor" stroke="none"></circle><circle cx="6" cy="14" r="1.5" fill="currentColor" stroke="none"></circle><circle cx="9" cy="16" r="1.5" fill="currentColor" stroke="none"></circle></svg>`,
  'REST APIs': `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`,
};

const defaultIcon = `<span style="font-size: 40px;">⚙️</span>`;
---

<section id="skills" class="py-20 bg-dark/50">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12 text-center" data-aos="fade-up">Skills</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
      {skills.map((skill, i) => (
        <div
          class="flex flex-col items-center p-6 bg-white/5 rounded-xl hover:bg-accent/10 border border-white/5 hover:border-accent/50 transition-all"
          data-aos="zoom-in"
          data-aos-delay={i * 100}
        >
          <div class="mb-3 text-accent" set:html={skillIcons[skill.name] || defaultIcon} />
          <span class="text-sm font-medium text-center">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>