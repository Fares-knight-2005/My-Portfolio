---
import personal from '../data/personal.json';
import TypewriterWrapper from './TypewriterWrapper.jsx';

const base = import.meta.env.BASE_URL || '/';
const avatarSrc = `${base}/${personal.avatar.replace(/^\//, '')}`;
const cvHref = `${base}/${personal.cv.replace(/^\//, '')}`;
---

<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
  <div class="container mx-auto px-6 text-center relative z-10">
    <img
      src={avatarSrc}
      alt={personal.name}
      class="w-72 h-56 md:w-96 md:h-72 rounded-[40%] mx-auto mb-8 border-4 border-accent/50 shadow-lg shadow-accent/20 object-cover"
    />
    <h1 class="text-5xl md:text-7xl font-bold mb-4">
      {personal.name}
    </h1>
    <div class="text-2xl md:text-3xl text-accent h-10 mb-6">
      <TypewriterWrapper
        client:load
        texts={['.Net Core', 'Backend Developer', 'T_SQL' , 'Asp.Net Core', 'ADO.Net' , 'Rest Apis' , 'SQL Sever' , 'Entity Freamwork' , ' Problem Solver']}
      />
    </div>
    <p class="max-w-2xl mx-auto text-lg text-gray-400 mb-8">
      {personal.bio}
    </p>
    <div class="flex justify-center gap-4">
      <a href={cvHref} download class="px-6 py-3 bg-accent text-dark font-semibold rounded-full hover:bg-accent/80 transition">
        Download CV
      </a>
      <a href="#contact" class="px-6 py-3 border border-accent text-accent rounded-full hover:bg-accent/10 transition">
        Contact Me
      </a>
    </div>
  </div>
</section>