---
import education from '../data/education.json';
---

<section id="education" class="py-20 bg-dark/50">
  <div class="container mx-auto px-6 max-w-3xl">
    <h2 class="text-3xl font-bold mb-12 text-center" data-aos="fade-up">Education & Certificates</h2>
    <div class="relative border-r-2 border-accent/50">
      {education.map((item, i) => (
        <div class="mb-10 mr-8 relative" data-aos="fade-left" data-aos-delay={i * 100}>
          <div class="absolute -right-[45px] bg-dark border-2 border-accent rounded-full w-8 h-8 flex items-center justify-center">
            <div class="w-2 h-2 bg-accent rounded-full"></div>
          </div>
          <h3 class="text-xl font-semibold">{item.degree}</h3>
          <p class="text-accent text-sm">{item.institution} | {item.year}</p>
          <p class="text-gray-400 mt-1">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>